<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="1" author="support_candidate">
        <createTable tableName="producers">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="products">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="CLOB"/>
            <column name="price" type="DECIMAL(19, 2)"/>
            <column name="producer_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_product_producer" referencedTableName="producers" referencedColumnNames="id"/>
            </column>
        </createTable>

        <createTable tableName="product_attributes">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="product_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_attr_product" referencedTableName="products" referencedColumnNames="id"/>
            </column>
            <column name="attr_key" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="attr_value" type="VARCHAR(1000)"/>
        </createTable>
    </changeSet>

</databaseChangeLog>